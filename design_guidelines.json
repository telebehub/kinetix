        "description": "Baku Skyline for Welcome/Loading Screen"
      },
      {
        "category": "bus_promo",
        "url": "https://images.unsplash.com/photo-1767990495590-b8fde2270e02?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjAzNDR8MHwxfHNlYXJjaHwxfHxtb2Rlcm4lMjBlbGVjdHJpYyUyMGJ1cyUyMGNpdHklMjBzdHJlZXR8ZW58MHx8fHwxNzczNDg2ODI4fDA&ixlib=rb-4.1.0&q=85",
        "description": "Modern Green Electric Bus for 'Bus Mode' promo or ticket bg"
      },
      {
        "category": "metro_promo",
        "url": "https://images.unsplash.com/photo-1765355683024-c638d3704fb5?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NDk1ODB8MHwxfHNlYXJjaHwyfHxtb2Rlcm4lMjBzdWJ3YXklMjB0cmFpbiUyMHN0YXRpb24lMjBwbGF0Zm9ybXxlbnwwfHx8fDE3NzM0ODY4Mjl8MA&ixlib=rb-4.1.0&q=85",
        "description": "Subway Station for 'Metro Mode' promo"
      }
